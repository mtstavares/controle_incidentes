SECRET_KEY=troque-por-uma-chave-gerada-com-openssl-rand-hex-32
DATABASE_URL=sqlite:////app/instance/divciber.db
TIMEZONE=America/Sao_Paulo
DIVCIBER_PORT=5005
GUNICORN_WORKERS=1
PM_API_BASE_URL=https://webservices.intranet.policiamilitar.sp.gov.br/pmesp.cdpm/api/v1/PolicialMilitar
PM_API_TIMEOUT=10
# Ambiente intranet atual usa certificado interno não confiado pelo container.
PM_API_VERIFY_TLS=0
# Alternativa preferencial: configurar a CA interna e voltar PM_API_VERIFY_TLS=1.
# PM_API_CA_BUNDLE=/app/instance/certs/ca-interna.pem
PM_SEARCH_CACHE_TTL_SECONDS=300
